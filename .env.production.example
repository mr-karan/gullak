# Gullak Production Configuration
# Copy this file to .env and configure the required values.
#
# REQUIRED: You must set at least one LLM API key.
# OPTIONAL: Everything else has sensible defaults.

# =============================================================================
# REQUIRED: LLM Provider (choose one)
# =============================================================================

# Option 1: OpenRouter (RECOMMENDED - one key for all models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: Direct provider keys (uncomment the one you want to use)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# OPTIONAL: Model Selection
# =============================================================================
# Default model works great. Only change if you have a preference.
# See https://openrouter.ai/models for available models.

GULLAK_INFERENCE_MODEL=openrouter/google/gemini-2.0-flash-001

# =============================================================================
# OPTIONAL: Your Preferences
# =============================================================================

# Currency symbol for transactions (USD, EUR, GBP, INR, etc.)
GULLAK_DEFAULT_CURRENCY=USD

# Your timezone (affects transaction dates)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# =============================================================================
# OPTIONAL: WhatsApp Security
# =============================================================================
# If using WhatsApp integration, set these for security.

# API key for the WhatsApp bridge (generate with: openssl rand -hex 16)
# GULLAK_WHATSAPP_API_KEY=your-random-api-key-here

# Restrict which phone numbers can send messages (JSON array, no + prefix)
# REQUIRED: App will NOT start without this set.
# Comma-separated phone numbers with country code (no + prefix).
GULLAK_WHATSAPP_ALLOWED_NUMBERS=919650318721,919990577075

# =============================================================================
# OPTIONAL: Network Binding
# =============================================================================
# By default, services bind to 127.0.0.1 (localhost only).
# To expose to all interfaces (e.g., behind a reverse proxy), use 0.0.0.0:PORT

# Gullak web UI port (default: localhost only)
# GULLAK_HOST_PORT=127.0.0.1:8000

# Paisa dashboard port (default: localhost only)  
# PAISA_HOST_PORT=127.0.0.1:7500

# To expose to network (use with reverse proxy + HTTPS):
# GULLAK_HOST_PORT=0.0.0.0:8000
# PAISA_HOST_PORT=0.0.0.0:7500

# =============================================================================
# OPTIONAL: Advanced
# =============================================================================

# File permissions (match your host user's UID/GID for volume access)
# Find yours with: id -u && id -g
# GULLAK_UID=1000
# GULLAK_GID=1000

# Ledger filename (stored in Docker volume)
# GULLAK_LEDGER_FILE=main.ledger

# Max tokens for LLM context
# GULLAK_INFERENCE_CONTEXT_LENGTH=8192
