# Gullak Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# INFERENCE CONFIGURATION
# =============================================================================
# Model to use (LiteLLM format). See: https://docs.litellm.ai/docs/providers
# Default: openrouter/google/gemini-2.0-flash-001
#
# OpenRouter examples (recommended - single API for all providers):
#   GULLAK_INFERENCE_MODEL=openrouter/google/gemini-2.0-flash-001
#   GULLAK_INFERENCE_MODEL=openrouter/anthropic/claude-3.5-sonnet
#   GULLAK_INFERENCE_MODEL=openrouter/openai/gpt-4o
#
# Direct provider examples:
#   GULLAK_INFERENCE_MODEL=gpt-4o                    # OpenAI
#   GULLAK_INFERENCE_MODEL=gemini/gemini-2.0-flash   # Google AI
#   GULLAK_INFERENCE_MODEL=claude-sonnet-4-20250514  # Anthropic
#   GULLAK_INFERENCE_MODEL=ollama/llama3             # Local Ollama

GULLAK_INFERENCE_MODEL=openrouter/google/gemini-2.0-flash-001

# =============================================================================
# PROVIDER API KEYS (set the one matching your model)
# =============================================================================

# OpenRouter - recommended for multi-provider access via single API
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Direct provider access (use if not using OpenRouter)
# OPENAI_API_KEY=sk-your-openai-key
# GOOGLE_API_KEY=your-google-ai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# For local Ollama (no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# OPTIONAL: ADVANCED INFERENCE SETTINGS
# =============================================================================

# Max tokens to pass to model (default: 8192)
# GULLAK_INFERENCE_CONTEXT_LENGTH=8192

# Custom OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Currency for transactions (default: INR)
# GULLAK_DEFAULT_CURRENCY=INR

# Timezone (default: Asia/Kolkata)
# GULLAK_TIMEZONE=Asia/Kolkata

# Debug mode (default: false)
# GULLAK_DEBUG=false

# Server settings
# GULLAK_HOST=0.0.0.0
# GULLAK_PORT=8000

# Paisa integration (Docker Compose sets internal URL automatically)
# GULLAK_PAISA_URL=http://localhost:7500
# Browser-accessible URL for "Open Paisa" link (set this in Docker environments)
# GULLAK_PAISA_EXTERNAL_URL=http://localhost:7500

# =============================================================================
# WHATSAPP INTEGRATION (Optional)
# =============================================================================
# Gullak can receive expense messages via WhatsApp using a Baileys-based bridge.
# See Settings page in the UI to scan the QR code and link your device.
#
# Setup:
# 1. Run: docker compose up
# 2. Open http://localhost:8000 → Settings → WhatsApp Integration
# 3. Scan the QR code with WhatsApp
# 4. Send a message like "coffee 50 rupees" to the linked number
#
# Testing endpoints directly:
#   http://localhost:3000/api/status      - Connection status
#   http://localhost:3000/api/default/auth/qr - QR code image (when not connected)

# API key for WhatsApp bridge (optional, leave empty for local dev)
# If set, all requests to the bridge require X-API-Key header
# GULLAK_WHATSAPP_API_KEY=

# WhatsApp bridge URL (Docker Compose sets this automatically)
# GULLAK_WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:3000

# Security: Restrict which phone numbers can interact with the bot.
# Format: JSON array of phone numbers with country code (no + prefix).
# If empty, all numbers are allowed (not recommended for production).
# Example: GULLAK_WHATSAPP_ALLOWED_NUMBERS='["919876543210", "919988776655"]'
# GULLAK_WHATSAPP_ALLOWED_NUMBERS='[]'

# Group chat behavior: If true, only process messages starting with @gullak
# Default: false (process all messages from allowed numbers in groups)
# GULLAK_WHATSAPP_GROUP_REQUIRE_MENTION=false
