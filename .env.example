# Gullak Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# INFERENCE CONFIGURATION
# =============================================================================
# Model to use (LiteLLM format). See: https://docs.litellm.ai/docs/providers
# Default: openrouter/google/gemini-2.0-flash-001
#
# OpenRouter examples (recommended - single API for all providers):
#   GULLAK_INFERENCE_MODEL=openrouter/google/gemini-2.0-flash-001
#   GULLAK_INFERENCE_MODEL=openrouter/anthropic/claude-3.5-sonnet
#   GULLAK_INFERENCE_MODEL=openrouter/openai/gpt-4o
#
# Direct provider examples:
#   GULLAK_INFERENCE_MODEL=gpt-4o                    # OpenAI
#   GULLAK_INFERENCE_MODEL=gemini/gemini-2.0-flash   # Google AI
#   GULLAK_INFERENCE_MODEL=claude-sonnet-4-20250514  # Anthropic
#   GULLAK_INFERENCE_MODEL=ollama/llama3             # Local Ollama

GULLAK_INFERENCE_MODEL=openrouter/google/gemini-2.0-flash-001

# =============================================================================
# PROVIDER API KEYS (set the one matching your model)
# =============================================================================

# OpenRouter - recommended for multi-provider access via single API
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Direct provider access (use if not using OpenRouter)
# OPENAI_API_KEY=sk-your-openai-key
# GOOGLE_API_KEY=your-google-ai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# For local Ollama (no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# OPTIONAL: ADVANCED INFERENCE SETTINGS
# =============================================================================

# Max tokens to pass to model (default: 8192)
# GULLAK_INFERENCE_CONTEXT_LENGTH=8192

# Custom OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Currency for transactions (default: INR)
# GULLAK_DEFAULT_CURRENCY=INR

# Timezone (default: Asia/Kolkata)
# GULLAK_TIMEZONE=Asia/Kolkata

# Debug mode (default: false)
# GULLAK_DEBUG=false

# Server settings
# GULLAK_HOST=0.0.0.0
# GULLAK_PORT=8000

# Paisa integration URL (Docker Compose sets this automatically)
# GULLAK_PAISA_URL=http://localhost:7500
