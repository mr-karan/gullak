# Port the bridge listens on
PORT=3000

# Where pi-server receives webhooks
WEBHOOK_URL=http://localhost:8787/v1/whatsapp/webhook

# Baileys auth/session directory (relative or absolute)
AUTH_DIR=./auth_state

# Shared secret required on /api/* calls (also sent on outbound webhook)
GULLAK_WHATSAPP_API_KEY=

# Allowlists (optional). Empty = allow all DMs / all groups.
# Format: comma-separated, no @ suffixes.
ALLOWED_PHONE_NUMBERS=
ALLOWED_GROUPS=

LOG_LEVEL=warn
