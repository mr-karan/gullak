{
  "name": "Gullak",
  "short_name": "Gullak",
  "description": "AI-powered expense tracker with natural language input",
  "id": "/",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#0C0C0F",
  "theme_color": "#4338CA",
  "orientation": "portrait-primary",
  "categories": ["finance", "productivity"],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "icons": [
    {
      "src": "/static/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/static/icons/icon-maskable.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Expense",
      "short_name": "Add",
      "description": "Log a new expense",
      "url": "/?action=new",
      "icons": [{ "src": "/static/icons/shortcut-add.svg", "sizes": "96x96", "type": "image/svg+xml" }]
    },
    {
      "name": "Transactions",
      "short_name": "Txns",
      "description": "View recent transactions",
      "url": "/#transactions",
      "icons": [{ "src": "/static/icons/shortcut-list.svg", "sizes": "96x96", "type": "image/svg+xml" }]
    }
  ]
}
