              "resource": "transactions",
              "entityId": "txn-1",
              "field": "categoryId",
              "value": null
            }
          ]
        }
      ],
      "expectedStateJson": "{\"candidates\":[{\"context\":{},\"dot\":{\"actorId\":\"phone\",\"sequence\":1},\"lamport\":1,\"value\":null}]}",
      "expectedValue": null,
      "expectedConflictCount": 0
    }
  ],
