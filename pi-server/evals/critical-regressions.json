{
  "id": "critical-regressions",
  "title": "Critical Regression Cases",
  "defaults": {
    "ledgerFixture": "./fixtures/apr-21-regressions.ledger",
    "request": {
      "source": "api",
      "sourceUser": "eval-runner"
    }
  },
  "cases": [
    {
      "id": "single-shorthand-expense",
      "title": "Single shorthand expense should save without a payee clarification loop",
      "tags": ["expense", "shorthand", "regression"],
      "request": {
        "threadId": "eval:shorthand",
        "text": "302 groceries"
      },
      "expectations": {
        "action": "record_expense",
        "needsClarification": false,
        "ledgerChanged": true,
        "replyContains": ["302.00", "INR"],
        "replyExcludes": ["I apologize", "which payee", "To which payee"],
        "ledgerContains": ["302.00 INR"]
      }
    },
    {
      "id": "multi-shorthand-expense-batch",
      "title": "Multiple shorthand expenses in one message should save every item without a payee loop",
      "tags": ["expense", "batch", "shorthand", "regression"],
      "request": {
        "threadId": "eval:batch-shorthand",
        "text": "302 groceries\n871 groceries"
      },
      "expectations": {
        "needsClarification": false,
        "ledgerChanged": true,
        "replyContains": ["Saved these 2 expenses"],
        "replyExcludes": ["I apologize", "which payee", "To which payee"],
        "ledgerContains": ["302.00 INR", "871.00 INR"]
      }
    },
    {
      "id": "quoted-text-fallback-targets-swiggy",
      "title": "Quoted text alone should still target the Swiggy transaction when the quoted message id is missing",
      "tags": ["quoted-reply", "edit", "targeting", "fallback", "regression"],
