            "updatedAt": "2026-04-21T11:20:00.000Z"
          }
        }
      },
      "request": {
        "threadId": "eval:quoted-text-fallback",
        "text": "paid via hdfc upi",
        "quotedText": "Got it. Saved 1200.00 INR for Swiggy."
      },
      "expectations": {
        "transactionId": "0a717873",
        "referencedTransactionIds": ["0a717873"],
        "needsClarification": false,
        "ledgerChanged": true,
        "replyContains": ["Updated", "0a717873"],
        "ledgerContains": ["Assets:Bank:HDFC:UPI  -1200.00 INR"]
      }
    },
