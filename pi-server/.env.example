# Chavanni pi-server config. Copy to .env (gitignored) and adjust. All vars are
# optional unless noted; the defaults below run a local, no-auth dev server.

# ── Storage ──────────────────────────────────────────────────────────────
CHAVANNI_DATA_DIR=../data
CHAVANNI_DB_PATH=../data/chavanni.db
CHAVANNI_TIMEZONE=Asia/Kolkata
CHAVANNI_DEFAULT_CURRENCY=INR

# ── HTTP + auth ──────────────────────────────────────────────────────────
CHAVANNI_HOST=127.0.0.1
CHAVANNI_PORT=8787
# Shared secret for the x-api-key header. Leave empty for an open dev server.
CHAVANNI_HTTP_API_KEY=
# Set true in production to refuse booting without CHAVANNI_HTTP_API_KEY.
CHAVANNI_REQUIRE_AUTH=false

# ── AI model (optional) ──────────────────────────────────────────────────
# If no real key resolves, /v1/ai/* returns 503 (AI is simply disabled).
CHAVANNI_MODEL_BASE_URL=http://localhost:11434/v1
CHAVANNI_MODEL_ID=gpt-oss:20b
CHAVANNI_MODEL_NAME=GPT-OSS 20B
CHAVANNI_MODEL_API_KEY=
CHAVANNI_MODEL_REASONING=true
CHAVANNI_MODEL_THINKING_LEVEL=minimal
# Allow OPENROUTER_API_KEY / OPENAI_API_KEY from the ambient env to be used as
# the model key (off by default so stray env keys aren't picked up silently).
CHAVANNI_ALLOW_AMBIENT_MODEL_KEYS=false
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# ── WhatsApp bridge (optional) ───────────────────────────────────────────
CHAVANNI_WHATSAPP_BRIDGE_URL=http://localhost:3000
CHAVANNI_WHATSAPP_API_KEY=
CHAVANNI_WHATSAPP_ALLOWED_NUMBERS=[]
CHAVANNI_WHATSAPP_GROUP_REQUIRE_MENTION=false

# ── Export: Google Sheets (optional, opt-in) ─────────────────────────────
# Set BOTH to enable the Apps Script export destination. The secret must match
# the CHAVANNI_SECRET script property in the bound Apps Script. See docs.
CHAVANNI_SHEETS_WEBAPP_URL=
CHAVANNI_SHEETS_SECRET=
# Periodic push cadence in minutes; 0 disables the timer (push still fires
# after each /v1/sync/push).
CHAVANNI_SHEETS_SYNC_INTERVAL_MIN=0

# ── Export: Actual Budget (optional, opt-in) ─────────────────────────────
# Enabled when SERVER_URL + PASSWORD + SYNC_ID are all set. Uses @actual-app/api
# (bundled; its native better-sqlite3 runs in-process on the Node runtime). Fires
# after each /v1/sync/push alongside Sheets. See ../docs/destinations.md.
CHAVANNI_ACTUAL_SERVER_URL=
CHAVANNI_ACTUAL_PASSWORD=
CHAVANNI_ACTUAL_SYNC_ID=
# Account to import into; defaults to the first account in the budget.
CHAVANNI_ACTUAL_ACCOUNT_ID=
