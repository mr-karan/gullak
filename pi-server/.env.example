# Gullak pi-server config. Copy to .env (gitignored) and adjust. All vars are
# optional unless noted; the defaults below run a local, no-auth dev server.

# ── Storage ──────────────────────────────────────────────────────────────
GULLAK_DATA_DIR=../data
GULLAK_DB_PATH=../data/gullak.db
GULLAK_TIMEZONE=Asia/Kolkata
GULLAK_DEFAULT_CURRENCY=INR

# ── HTTP + auth ──────────────────────────────────────────────────────────
GULLAK_HOST=127.0.0.1
GULLAK_PORT=8787
# Shared secret for the x-api-key header. Leave empty for an open dev server.
GULLAK_HTTP_API_KEY=
# Set true in production to refuse booting without GULLAK_HTTP_API_KEY.
GULLAK_REQUIRE_AUTH=false

# ── AI model (optional) ──────────────────────────────────────────────────
# If no real key resolves, /v1/ai/* returns 503 (AI is simply disabled).
GULLAK_MODEL_BASE_URL=http://localhost:11434/v1
GULLAK_MODEL_ID=gpt-oss:20b
GULLAK_MODEL_NAME=GPT-OSS 20B
GULLAK_MODEL_API_KEY=
GULLAK_MODEL_REASONING=true
GULLAK_MODEL_THINKING_LEVEL=minimal
# Allow OPENROUTER_API_KEY / OPENAI_API_KEY from the ambient env to be used as
# the model key (off by default so stray env keys aren't picked up silently).
GULLAK_ALLOW_AMBIENT_MODEL_KEYS=false
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# ── WhatsApp bridge (optional) ───────────────────────────────────────────
GULLAK_WHATSAPP_BRIDGE_URL=http://localhost:3000
GULLAK_WHATSAPP_API_KEY=
GULLAK_WHATSAPP_ALLOWED_NUMBERS=[]
GULLAK_WHATSAPP_GROUP_REQUIRE_MENTION=false

# ── Export: Google Sheets (optional, opt-in) ─────────────────────────────
# Set BOTH to enable the Apps Script export destination. The secret must match
# the GULLAK_SECRET script property in the bound Apps Script. See docs.
GULLAK_SHEETS_WEBAPP_URL=
GULLAK_SHEETS_SECRET=
# Periodic push cadence in minutes; 0 disables the timer (push still fires
# only when manually triggered).
GULLAK_SHEETS_SYNC_INTERVAL_MIN=0

# ── Export: Actual Budget (optional, opt-in) ─────────────────────────────
# Enabled when SERVER_URL + PASSWORD + SYNC_ID are all set. Uses @actual-app/api
# (bundled; its native better-sqlite3 runs in-process on the Node runtime). Fires
# on the configured interval alongside Sheets. See ../docs/destinations.md.
GULLAK_ACTUAL_SERVER_URL=
GULLAK_ACTUAL_PASSWORD=
GULLAK_ACTUAL_SYNC_ID=
# Account to import into; defaults to the first account in the budget.
GULLAK_ACTUAL_ACCOUNT_ID=
